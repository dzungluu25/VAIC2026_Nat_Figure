# Copy this file to .env and fill in real values. Never commit .env itself.

# --- Server ---
PORT=3000
NODE_ENV=development

# --- Auth ---
AUTH_JWT_SECRET=change-me-to-a-long-random-string
DEMO_OFFICER_PASSWORD=
DEMO_APPROVER_PASSWORD=
# Public, passwordless demo session endpoint. Defaults to enabled outside production.
ENABLE_PUBLIC_DEMO_SESSION=true

# --- FPT Cloud AI Marketplace (OpenAI-compatible) ---
# Get this from the FPT Cloud AI Marketplace console (API Keys section) for your project/org.
LEGAL_LLM_API_KEY=
LEGAL_LLM_BASE_URL=https://mkp-api.fptcloud.com
# One model per role — override any of these to test a different model without code changes.
LEGAL_LLM_MODEL=GLM-5.1
PLANNER_LLM_MODEL=DeepSeek-V4-Flash
EXTRACTION_LLM_MODEL=DeepSeek-V4-Flash

# --- Supabase (required — Postgres always connects through this pooler URL) ---
SUPABASE_DB_URL=
# Supabase pooler CA cert (PEM content or path to .crt/.pem) — enables verified TLS. Required in production.
SUPABASE_CA_CERT=
# Escape hatch: skip TLS verification (non-production only). Leave false/unset for verified connections.
SUPABASE_DB_SSL_INSECURE=false
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Profitability / RAROC overrides (optional; track market/ALCO changes without editing policy JSON) ---
# Rates must be 0..1; cost/percent/minute values must be >= 0. Applied overrides are logged in policyMetadata.
# PROFITABILITY_FUNDING_COST_RATE=
# PROFITABILITY_EXPECTED_LOSS_RATE=
# PROFITABILITY_CAPITAL_ALLOCATION_RATE=
# PROFITABILITY_CAPITAL_HURDLE_RATE=
# PROFITABILITY_AUTOMATED_CASE_COST_VND=
# PROFITABILITY_MANUAL_CASE_COST_VND=
# PROFITABILITY_MANUAL_PROCESSING_MINUTES=
# PROFITABILITY_MINIMUM_RAROC_PERCENT=

# --- Neo4j (legal knowledge graph) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=vaic_neo_pass

# --- Google Document AI (OCR for document intake module) ---
# Service account key JSON (full contents, not a file path) for a GCP project with a
# Document AI processor enabled. Get this from GCP Console > IAM > Service Accounts.
GOOGLE_APPLICATION_CREDENTIALS_JSON=
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_DOCUMENT_AI_LOCATION=us
# Processor ID of a Document OCR / Form Parser processor (GCP Console > Document AI > Processors).
GOOGLE_DOCUMENT_AI_PROCESSOR_ID=

# --- Gmail SMTP (missing-document notification emails) ---
# Requires a Gmail App Password (Google Account > Security > App passwords), not the account password.
GMAIL_SMTP_USER=
GMAIL_SMTP_APP_PASSWORD=
GMAIL_SENDER_NAME=SHB VAIC Credit Ops

# --- Supabase Storage (original document files for the intake module) ---
SUPABASE_STORAGE_BUCKET=loan-documents
