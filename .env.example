# Backend / Express Configuration
PORT=3000
NODE_ENV=development

# PostgreSQL Connection (Docker internal host is 'postgres', local host is 'localhost')
# For Supabase, set SUPABASE_DB_URL to the Connection Pooler URL (Transaction Mode - port 6543)
PG_HOST=postgres
PG_PORT=5432
PG_USER=vaic
PG_PASSWORD=vaic_pass
PG_DB=vaic_db

# Supabase Configuration
# Provide these keys from your Supabase Project Settings > API
SUPABASE_URL=https://your-project-id.supabase.co
# Use SERVICE_ROLE_KEY for backend to bypass RLS, or ANON_KEY if RLS policies are strictly defined for this backend service.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
# The Postgres connection URL from Supabase for raw SQL DDL
SUPABASE_DB_URL=postgres://postgres.[project-id]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Redis Connection (Docker internal host is 'redis', local host is 'localhost')
REDIS_URL=redis://redis:6379

# Neo4j Connection (Docker internal host is 'neo4j', local host is 'localhost')
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=vaic_neo_pass

# Auth: JWT signing secret for session + approval tokens.
# REQUIRED — the server refuses to start signing/verifying tokens without it.
# Generate a real value with: openssl rand -hex 32
AUTH_JWT_SECRET=change_me_to_a_long_random_secret

# Auth: bootstrap passwords for the demo identity directory
# (services/auth/demo-user.store.ts) — replace with real SSO/AD integration before production.
DEMO_OFFICER_PASSWORD=change_me_officer_password
DEMO_APPROVER_PASSWORD=change_me_approver_password
# Optional demo identities for RBAC review; unset accounts cannot log in.
DEMO_CUSTOMER_PASSWORD=change_me_customer_password
DEMO_ADMIN_PASSWORD=change_me_admin_password
DEMO_AUDITOR_PASSWORD=change_me_auditor_password

# Public hackathon UI: issue a short-lived CREDIT_OFFICER demo token without a login form.
# Keep false in production unless the deployment is intentionally a public sandbox.
ENABLE_PUBLIC_DEMO_SESSION=true

# FPT AI Marketplace (OpenAI-compatible) for routing and Legal Agent reasoning
FPT_MARKETPLACE_API_KEY=
FPT_MARKETPLACE_BASE_URL=https://mkp-api.fptcloud.com
FPT_LEGAL_MODEL=gpt-oss-120b

# Free local OCR (Tesseract). Docker already includes the binaries and Vietnamese model.
OCR_LANGUAGES=vie+eng
OCR_PDF_DPI=200
OCR_MAX_PDF_PAGES=10
# Only override these when running outside Docker and binaries are not on PATH.
TESSERACT_COMMAND=tesseract
PDFTOPPM_COMMAND=pdftoppm

# Optional generic aliases for a reviewed fine-tuned model served by FPT LoRA,
# vLLM, or another OpenAI-compatible private endpoint. These take precedence.
LEGAL_LLM_API_KEY=
LEGAL_LLM_BASE_URL=
LEGAL_LLM_MODEL=

# Frontend Configuration
VITE_API_URL=http://localhost:3000
